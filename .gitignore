# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# electron build (bản cài đặt .exe quá nặng, đưa lên GitHub Release thay vì git)
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ảnh người dùng tải lên/dán bằng tay (không commit)
/public/uploads/*
!/public/uploads/.gitkeep

# database SQLite local (dữ liệu, không phải code — mỗi máy tự có riêng)
/prisma/*.db
/prisma/*.db-journal
