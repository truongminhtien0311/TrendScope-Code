// ============================================================
// SCHEMA DATABASE — Product Scrap
// Database: SQLite (1 file nằm trong prisma/dev.db) — mỗi người tự chạy
// app độc lập trên máy riêng (không còn server/VPS chung), dữ liệu gộp
// lại qua tính năng Đồng bộ (xuất/nhập qua Google Drive, xem src/lib/sync/).
// Migration quản lý bằng `prisma migrate` (không dùng `db push`).
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// NGƯỜI DÙNG — role "admin" | "member" (member bị requireAdmin() chặn
// các thao tác nhạy cảm, xem src/lib/auth.ts). isOwner đánh dấu tài
// khoản gốc (chủ app, thường chỉ 1 người) — vẫn là admin bình thường ở
// mọi nơi khác, chỉ khác 1 điểm: CHỈ owner mới xóa được tài khoản admin
// khác (2 admin thường không xóa lẫn nhau được, tránh 1 admin phụ tự ý
// xóa chủ tài khoản hoặc admin khác) — xem DELETE /api/auth/users/[id].
// ------------------------------------------------------------
model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String
  passwordHash String? // sẽ dùng khi làm chức năng đăng nhập
  role         String        @default("member") // "admin" | "member"
  isOwner      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  logs         ActivityLog[]
}

// ------------------------------------------------------------
// NGÀNH HÀNG & TAG — người dùng tự thêm/xóa được (theo mindmap)
// ------------------------------------------------------------
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  icon     String? // emoji đại diện, vd "👗" — hiển thị ghép "emoji + tên"
  products Product[]
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  color    String? // mã màu hex để hiển thị, vd "#f59e0b"
  icon     String? // emoji đại diện, vd "🔥" — hiển thị ghép "emoji + tên"
  products Product[]
}

// ------------------------------------------------------------
// SẢN PHẨM (Mục mẹ trong mindmap)
// Một sản phẩm gom nhiều link nguồn: shop bán lẻ (Taobao, Tmall, JD)
// và nhà sản xuất (Alibaba, 1688) — mỗi link là 1 Listing bên dưới.
// ------------------------------------------------------------
model Product {
  id          Int       @id @default(autoincrement())
  // Mã ổn định sinh 1 lần, dùng để nhận diện sản phẩm XUYÊN SUỐT các máy
  // khác nhau khi đồng bộ (id tự tăng chỉ có ý nghĩa trong 1 database,
  // không dùng để chống trùng giữa máy này với máy khác được) — xem
  // src/lib/sync/index.ts.
  uuid        String    @unique @default(uuid())
  name        String // người dùng tự đặt/đổi tên
  description String? // mô tả do người dùng tự viết

  // Kết quả AI: xem model ProductAiAnalysis bên dưới — mỗi lần "Tạo bằng
  // AI" tạo 1 dòng MỚI (giữ lịch sử tối đa 10 bản/sản phẩm) thay vì ghi
  // đè 1 bộ cột duy nhất như trước.

  // Ảnh đại diện của sản phẩm lấy từ link nào (chọn tay).
  // Để trống = theo luật mặc định: ưu tiên shop bán lẻ, shop nào
  // thêm sớm nhất lấy trước; không có bán lẻ thì lấy nhà sản xuất.
  // (xem src/lib/product-image.ts)
  mainImageListingId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  categories  Category[] // cho phép gắn NHIỀU ngành hàng (giống Tag)
  tags        Tag[]
  listings    Listing[]
  aiAnalyses    ProductAiAnalysis[]
  activityLogs  ActivityLog[]
}

// ------------------------------------------------------------
// LỊCH SỬ PHÂN TÍCH AI — mỗi lần bấm "Tạo bằng AI" tạo 1 dòng MỚI
// (không ghi đè dòng cũ) để giữ lại nhiều góc nhìn so sánh được, tối đa
// 10 dòng/sản phẩm (dòng cũ nhất tự bị xóa khi vượt quá, xem logic dọn
// dẹp trong src/app/api/products/[id]/analyze/route.ts). Route tạo dòng
// "PENDING" rồi trả response NGAY (không đợi Gemini) để hiển thị đồng hồ
// đếm giờ thật (dựa vào startedAt) sống sót qua việc bấm rời trang/F5 lại
// trang — xử lý Gemini chạy nền, xong thì cập nhật dòng này thành DONE/FAILED.
model ProductAiAnalysis {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  status    String  @default("PENDING") // "PENDING" | "DONE" | "FAILED"
  presetName String? // tên preset Prompt AI dùng để tạo bản này (xem lại biết ngữ cảnh)

  aiSummary       String?
  aiAudience      String?
  aiChannels      String?
  aiCustomization String?
  aiImportInfo    String?
  aiShipping      String?
  aiFeasibility   String?

  errorMessage String? // lý do lỗi nếu status = FAILED
  startedAt    DateTime  @default(now())
  finishedAt   DateTime? // null khi còn PENDING

  @@index([productId, startedAt])
}

// ------------------------------------------------------------
// LISTING = 1 link sản phẩm trên 1 sàn (kết quả cào dữ liệu)
// ------------------------------------------------------------
model Listing {
  id                  Int            @id @default(autoincrement())
  product             Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId           Int
  sourceType          String // "RETAIL" (shop bán lẻ) | "MANUFACTURER" (nhà sản xuất)
  platform            String // "TAOBAO" | "TMALL" | "JD" | "ALIBABA" | "C1688"
  url                 String
  externalId          String? // uid sản phẩm lấy từ mã QR (theo mindmap)
  sellerName          String?
  titleOriginal       String? // tên gốc tiếng Trung
  titleVi             String? // tên đã dịch sang tiếng Việt
  descriptionOriginal String? // mô tả text người bán đăng
  descriptionVi       String?
  soldTotal           Int? // tổng lượt bán (nếu sàn có)
  soldMonthly         Int? // lượt bán tháng (nếu sàn có)
  lastScrapedAt       DateTime? // lần cào dữ liệu gần nhất
  createdAt           DateTime       @default(now())
  variants            Variant[]
  images              ListingImage[]
  reviews             Review[]
}

// Phân loại sản phẩm (màu, size...) + giá theo từng phân loại.
// Giá chỉ lưu Nhân dân tệ; VNĐ được quy đổi lúc hiển thị theo
// tỷ giá trong bảng Setting (key "cny_vnd_rate") để luôn cập nhật.
// Người dùng sửa tay được tên/giá (giá quét về có thể sai — theo mindmap);
// priceEdited đánh dấu giá đã sửa tay để lần cào lại không ghi đè mất.
model Variant {
  id           Int     @id @default(autoincrement())
  listing      Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId    Int
  nameOriginal String
  nameVi       String?
  priceCny     Float
  priceEdited  Boolean @default(false)
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId Int
  url       String // link ảnh gốc trên sàn
  localPath String? // đường dẫn sau khi tải về máy/cloud (làm sau)
  kind      String // "MAIN" (đại diện) | "GALLERY" (ảnh phụ) | "DESCRIPTION" (ảnh trong mô tả)
  sortOrder Int     @default(0)
}

model Review {
  id              Int       @id @default(autoincrement())
  listing         Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId       Int
  contentOriginal String
  contentVi       String? // bản dịch tiếng Việt
  rating          Int? // 1-5 sao nếu có
  reviewedAt      DateTime?
}

// ------------------------------------------------------------
// API BÊN THỨ BA — mục "Cài đặt > API" trong mindmap.
// Mỗi dòng là 1 nhà cung cấp, bật/tắt và sửa key được.
// ------------------------------------------------------------
model ApiProvider {
  id         Int      @id @default(autoincrement())
  kind       String // "SCRAPER_RETAIL" | "SCRAPER_MANUFACTURER" | "LLM" | "TRANSLATE" | "STORAGE"
  name       String // vd "Mock (dữ liệu giả để test)", "Gemini", "Google Drive"
  baseUrl    String?
  apiKey     String?
  enabled    Boolean  @default(false)
  configJson String? // cấu hình thêm dạng JSON nếu cần
  createdAt  DateTime @default(now())
}

// Cài đặt chung dạng key-value (tỷ giá, theme mặc định, thư mục local...)
model Setting {
  key   String @id
  value String
}

// ------------------------------------------------------------
// LOG — ghi lại TOÀN BỘ lịch sử hoạt động (theo mindmap)
// ------------------------------------------------------------
model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String // vd "product.create", "listing.scrape", "provider.toggle"
  detail    String? // mô tả chi tiết, dễ đọc
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  // Liên kết THẬT tới sản phẩm liên quan (thay vì dò "#123" trong "detail"
  // bằng regex — dễ vỡ nếu câu chữ đổi sau này). Chỉ populate ở nơi cần
  // (hiện tại: lúc tạo sản phẩm mới, cho trang /reports) — KHÔNG truy hồi
  // gán cho các loại log khác. onDelete SetNull: xóa sản phẩm không làm
  // mất dòng log lịch sử, chỉ mất liên kết.
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId Int?
  createdAt DateTime @default(now())
}
