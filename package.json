{
  "name": "trendscope",
  "version": "1.0.3",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "electron:dev": "electron .",
    "electron:build": "next build && node scripts/electron-build.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "com.trendscope.app",
    "productName": "TrendScope",
    "icon": "build/icon.png",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/public"
      },
      {
        "from": "prisma/schema.prisma",
        "to": "prisma/schema.prisma"
      },
      {
        "from": "prisma/migrations",
        "to": "prisma/migrations"
      },
      {
        "from": "build/resources-node-modules",
        "to": "node_modules"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "TrendScope-Setup-${version}.${ext}"
    },
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "truongminhtien0311",
      "repo": "TrendScope-Code"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@google/genai": "^2.10.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "exceljs": "^4.4.0",
    "iron-session": "^8.0.4",
    "next": "16.2.10",
    "open": "^11.0.0",
    "playwright": "^1.61.1",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "zod": "^4.4.3"
  }
}
