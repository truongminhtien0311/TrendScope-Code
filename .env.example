# Copy file này thành .env rồi điền giá trị thật.
# File .env KHÔNG được đưa lên git (đã có trong .gitignore).

DATABASE_URL="file:./dev.db"

# Các API key bên thứ ba sẽ quản lý trong app (trang Cài đặt > API),
# không cần khai báo ở đây.

# Khóa mã hóa session đăng nhập — chuỗi ngẫu nhiên bất kỳ, ít nhất 32
# ký tự (tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET="doi-chuoi-nay-thanh-chuoi-ngau-nhien-it-nhat-32-ky-tu"
